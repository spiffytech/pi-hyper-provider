{
	"name": "@charmland/pi-hyper-provider",
	"version": "0.1.0",
	"description": "Charm Hyper provider extension for Pi",
	"keywords": [
		"pi-package"
	],
	"files": [
		"src",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
