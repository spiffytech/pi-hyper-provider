		"@earendil-works/pi-ai": "^0.78.0",
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"typescript": "^6.0.3"
	},
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/charmbracelet/pi-hyper-provider"
	}
