{
	"name": "@charmland/pi-hyper-provider",
	"version": "0.1.2",
	"description": "Pi extension for Charm's Hyper inference provider",
	"license": "MIT",
	"keywords": [
		"pi-package"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"fmt": "biome format --write .",
		"lint": "biome lint .",
		"check:biome": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "*"
	},
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@earendil-works/pi-ai": "^0.81.1",
		"@earendil-works/pi-coding-agent": "^0.81.1",
		"typebox": "^1.1.38",
		"typescript": "^6.0.3"
	},
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/charmbracelet/pi-hyper-provider"
	}
}
